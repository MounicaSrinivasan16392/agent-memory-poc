# Copy to .env and fill in secrets:
#   cp .env.example .env

# ── gRPC memory-api (server) ────────────────────────────────────────────────
GRPC_HOST=0.0.0.0
GRPC_PORT=50052

# gRPC client (chat demo / agents) — where memory-api listens
MEMORY_GRPC_HOST=127.0.0.1
MEMORY_GRPC_PORT=50052

# ── Postgres (docker-compose maps host 5433 → container 5432) ───────────────
DATABASE_URL=postgresql://memory:memory@127.0.0.1:5433/fluentmind_memory

# ── Redis — working memory (summary + recent turns) ─────────────────────────
# If Homebrew Redis runs on 6379, the app uses that instance (not Docker Redis).
# Stop Homebrew (`brew services stop redis`) or point Redis Insight at host.docker.internal.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
SESSION_TTL_SECONDS=2592000

# ── Qdrant — long-term memory content (one collection per agent) ────────────
QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION_PREFIX=

# ── RabbitMQ — async jobs (summarize, session_end). UI: http://localhost:15672
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672
RABBITMQ_EXCHANGE=memory
RABBITMQ_QUEUE=memory.jobs

# ── OpenAI — required for memory LLM jobs, embeddings, and chat demo ─────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# ── Memory platform policy (src/config.js → config.memory) ─────────────────
# MEMORY_RETRIEVAL_K=6
# MEMORY_SUMMARIZE_TOKEN_THRESHOLD=1000

# ── Chat demo HTTP UI ───────────────────────────────────────────────────────
CHAT_PORT=3000

